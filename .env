# ==========================================================
# Datasource (MySQL)
# ==========================================================
spring.datasource.url=jdbc:mysql://${MYSQL_HOST:mysql}:${MYSQL_PORT:3306}/${MYSQL_DB:ecommerce_db}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
spring.datasource.username=${MYSQL_USER:ecommerce}
spring.datasource.password=${MYSQL_PASSWORD:ecommerce}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# HikariCP
spring.datasource.hikari.maximum-pool-size=10
spring.datasource.hikari.minimum-idle=2

# JPA / Hibernate
spring.jpa.hibernate.ddl-auto=none
spring.jpa.show-sql=false
spring.jpa.database-platform=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.type.preferred_uuid_jdbc_type=CHAR

# Liquibase
spring.liquibase.change-log=classpath:db/changelog/db.changelog-master.yaml
spring.liquibase.enabled=true

# ==========================================================
# Redis
# ==========================================================
spring.redis.host=${REDIS_HOST:redis}
spring.redis.port=${REDIS_PORT:6379}

# ==========================================================
# MinIO
# ==========================================================
minio.url=http://${MINIO_HOST:localhost}:${MINIO_PORT:9000}
minio.console-url=http://${MINIO_HOST:localhost}:${MINIO_CONSOLE_PORT:9001}
minio.access-key=${MINIO_ROOT_USER:minioadmin}
minio.secret-key=${MINIO_ROOT_PASSWORD:minioadmin}
minio.bucket=app-bucket

# ==========================================================
# JWT
# ==========================================================
jwt.secret=${JWT_SECRET:Zm9ydHktdHdvLWlzLXRoZS1hbnN3ZXItdG8tbGlmZS10aGUtdW5pdmVyc2UtYW5kLWV2ZXJ5dGhpbmc=}
jwt.expiration=${JWT_EXPIRATION:3600000}

# ==========================================================
# Server
# ==========================================================
server.port=${APP_PORT:8080}
spring.profiles.active=${SPRING_PROFILES_ACTIVE:dev}

