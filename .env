# =========================
# Environment variables
# =========================

# ---------- Database (MySQL) ----------
# Dùng 'localhost' khi chạy lệnh từ máy thật (Maven, migrate-up)
# Dùng 'mysql' (tên service) nếu chạy ứng dụng bên trong Docker
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=ecommerce_db
MYSQL_USER=ecommerce
MYSQL_PASSWORD=ecommerce

# JDBC URL cho Liquibase (Chạy từ máy thật nên dùng localhost qua MYSQL_HOST ở trên)
LIQUIBASE_URL=jdbc:mysql://${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DB}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
LIQUIBASE_USER=${MYSQL_USER}
LIQUIBASE_PASSWORD=${MYSQL_PASSWORD}

# ---------- Liquibase Changelog Paths ----------
DOCKER_CHANGELOG=/liquibase/changelog/db.changelog-master.yaml

# File Master (Mục lục)
LOCAL_CHANGELOG=db/changelog/db.changelog-master.yaml

# Thư mục chứa các file migration thực tế (.sql)
# Đường dẫn này tính từ gốc project (root) để lệnh 'mkdir' và 'touch' của Makefile chạy đúng
CHANGELOG_DIR=src/main/resources/db/changelog/migrations

# ---------- Redis ----------
# Nếu chạy app local, hãy đổi thành localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------- MinIO ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------- App ----------
APP_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ---------- JWT ----------
JWT_SECRET=supersecretkey123
JWT_EXPIRATION=3600000